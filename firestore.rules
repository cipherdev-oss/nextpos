rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }

    function isOrgMember(orgId) {
      let userData = getUserData();
      return isSignedIn() && userData != null && userData.orgId == orgId;
    }

    function isOrgAdmin(orgId) {
      let userData = getUserData();
      return isSignedIn() && userData != null && userData.orgId == orgId && (userData.role == 'owner' || userData.role == 'admin');
    }

    // --- Validations ---

    function isValidOrg(data) {
      return data.keys().hasAll(['name', 'ownerId', 'createdAt', 'currency'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.ownerId == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidUserProfile(data) {
      return data.email is string
        && data.orgId is string
        && data.role in ['owner', 'admin', 'cashier'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['orgId', 'name', 'price', 'stock'])
        && data.orgId is string
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.price is number && data.price >= 0
        && data.stock is number
        && (data.keys().hasOnly(['orgId', 'name', 'price', 'cost', 'stock', 'sku', 'barcode', 'category', 'unit', 'minStock', 'imageUrl', 'createdAt', 'updatedAt']));
    }

    function isValidSale(data) {
      return data.keys().hasAll(['orgId', 'userId', 'items', 'total', 'createdAt'])
        && data.orgId is string
        && data.userId == request.auth.uid
        && data.items is list && data.items.size() > 0 && data.items.size() <= 50
        && data.total is number && data.total >= 0
        && data.createdAt == request.time
        && (data.keys().hasOnly(['orgId', 'userId', 'items', 'subtotal', 'tax', 'total', 'paymentMethod', 'cashTendered', 'changeDue', 'createdAt']));
    }

    // --- Collections ---

    // Users (Profiles)
    match /users/{userId} {
      allow list: if isSignedIn() && (
        (resource.data.email.lower() == request.auth.token.email.lower()) ||
        (getUserData() != null && getUserData().orgId == resource.data.orgId)
      );
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        (resource.data.email.lower() == request.auth.token.email.lower()) ||
        (getUserData() != null && getUserData().orgId == resource.data.orgId)
      );
      allow create: if isSignedIn() && (
        request.auth.uid == userId || (getUserData() != null && isOrgAdmin(incoming().orgId))
      ) && isValidUserProfile(incoming());
      
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])) ||
        (getUserData() != null && isOrgAdmin(existing().orgId) && isValidUserProfile(incoming()))
      ) && incoming().email == existing().email 
        && (existing().role == 'owner' || incoming().orgId == existing().orgId);

      // Allow deletion by admin OR self-adoption cleanup
      allow delete: if isSignedIn() && (
        (getUserData() != null && isOrgAdmin(existing().orgId) && userId != request.auth.uid && existing().role != 'owner') ||
        (request.auth.token.email.lower() == existing().email.lower())
      );
    }

    // Organizations
    match /orgs/{orgId} {
      allow get: if isValidId(orgId) && isOrgMember(orgId);
      allow create: if isSignedIn() && isEmailVerified() && isValidOrg(incoming());
      allow update: if isOrgAdmin(orgId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'currency', 'updatedAt'])
        && incoming().ownerId == existing().ownerId;

      // Products subcollection
      match /products/{productId} {
        allow list: if isOrgMember(orgId);
        allow get: if isOrgMember(orgId);
        allow create: if isOrgAdmin(orgId) && isValidProduct(incoming()) && incoming().orgId == orgId;
        allow update: if isOrgAdmin(orgId) && isValidProduct(incoming())
          && incoming().orgId == existing().orgId;
        allow delete: if isOrgAdmin(orgId);
      }

      // Categories subcollection
      match /categories/{categoryId} {
        allow list: if isOrgMember(orgId);
        allow get: if isOrgMember(orgId);
        allow create, update: if isOrgAdmin(orgId) && incoming().orgId == orgId;
        allow delete: if isOrgAdmin(orgId);
      }

      // Sales subcollection
      match /sales/{saleId} {
        allow list: if isOrgMember(orgId);
        allow get: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId) && isValidSale(incoming()) && incoming().orgId == orgId;
        allow update, delete: if false;
      }
    }
  }
}
